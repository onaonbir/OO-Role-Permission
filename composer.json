{
    "name": "onaonbir/oo-role-permission",
    "description": "Flexible and polymorphic role & permission system for Laravel with time-based constraints, wildcard matching, and middleware integration.",
    "type": "library",
    "version": "1.4.0",
    "license": "MIT",
    "homepage": "https://onaonbir.com",
    "keywords": [
        "laravel",
        "role",
        "permission",
        "authorization",
        "rbac",
        "polymorphic",
        "time-based",
        "wildcard",
        "middleware",
        "access-control"
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/cache": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "OnaOnbir\\OORolePermission\\": "src/"
        },
        "files": [
            "helpers/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "OnaOnbir\\OORolePermission\\OORolePermissionServiceProvider"
            ]
        }
    },
    "authors": [
        {
            "name": "OnaOnbir",
            "email": "dev@onaonbir.com",
            "homepage": "https://onaonbir.com"
        }
    ],
    "support": {
        "issues": "https://github.com/onaonbir/oo-role-permission/issues",
        "source": "https://github.com/onaonbir/oo-role-permission"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
